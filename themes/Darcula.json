{
  "name": "Darcula",
  "type": "dark",
  "colors": {
    "editor.background": "#2b2b2b",
    "editor.foreground": "#a9b7c6",
    "editorLineNumber.foreground": "#606366"
  },
  "tokenColors": [
    {
      "scope": "keyword",
      "settings": { "foreground": "#cc7832", "fontStyle": "bold" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#6a8759" }
    },
    {
      "scope": "comment",
      "settings": { "foreground": "#808080", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword.other.annotation", "storage.type.annotation"],
      "settings": { "foreground": "#bbb529" }
    },
    {
      "scope": "constant.numeric",
      "settings": { "foreground": "#6897bb" }
    },
    {
      "scope": ["variable.other.object", "entity.name.field"],
      "settings": { "foreground": "#9876aa" }
    },
    {
      "scope": ["variable.parameter", "entity.name.parameter"],
      "settings": { "foreground": "#a9b7c6" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#ffc66d" }
    },
    {
      "scope": ["entity.name.type", "storage.type.class", "support.class"],
      "settings": { "foreground": "#ffc66d" }
    },
    {
      "scope": "variable",
      "settings": { "foreground": "#a9b7c6" }
    }
  ]
}